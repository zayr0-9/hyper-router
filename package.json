{
  "name": "hyper-router",
  "version": "0.1.3",
  "description": "A minimal Node-first TypeScript agent runtime SDK boilerplate.",
  "repository": {
    "type": "git",
    "url": "https://github.com/zayr0-9/hyper-router.git"
  },
  "homepage": "https://github.com/zayr0-9/hyper-router#readme",
  "bugs": {
    "url": "https://github.com/zayr0-9/hyper-router/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers/openrouter": {
      "types": "./dist/providers/openrouter/index.d.ts",
      "import": "./dist/providers/openrouter/index.js"
    },
    "./providers/openai-vai": {
      "types": "./dist/providers/openai-vai/index.d.ts",
      "import": "./dist/providers/openai-vai/index.js"
    },
    "./providers/amazon-bedrock-vai": {
      "types": "./dist/providers/amazon-bedrock-vai/index.d.ts",
      "import": "./dist/providers/amazon-bedrock-vai/index.js"
    },
    "./storage/in-memory": {
      "types": "./dist/storage/in-memory.d.ts",
      "import": "./dist/storage/in-memory.js"
    },
    "./storage/json": {
      "types": "./dist/storage/json.d.ts",
      "import": "./dist/storage/json.js"
    },
    "./storage/sqlite": {
      "types": "./dist/storage/sqlite.d.ts",
      "import": "./dist/storage/sqlite.js"
    },
    "./storage/postgres": {
      "types": "./dist/storage/postgres.d.ts",
      "import": "./dist/storage/postgres.js"
    },
    "./storage/types": {
      "types": "./dist/storage/types.d.ts",
      "import": "./dist/storage/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx examples/basic.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:json-resume": "tsx examples/json-resume-demo.ts",
    "demo:sqlite-resume": "tsx examples/sqlite-resume-demo.ts",
    "demo:openrouter:gpt54-mini": "tsx examples/openrouter-gpt54-mini-demo.ts",
    "demo:openrouter:gpt54-mini:sqlite": "tsx examples/openrouter-gpt54-mini-sqlite-demo.ts",
    "smoke:openrouter:text": "tsx examples/openrouter-smoke.ts",
    "smoke:openrouter:tool": "tsx examples/openrouter-tool-smoke.ts",
    "smoke:openrouter:image": "tsx examples/openrouter-image-smoke.ts",
    "smoke:openrouter:chain": "tsx examples/openrouter-tool-chain-smoke.ts",
    "smoke:openrouter:runtime": "tsx examples/openrouter.ts",
    "smoke:openai:text": "tsx examples/openai-smoke.ts",
    "smoke:openai:tool": "tsx examples/openai-tool-smoke.ts",
    "smoke:openai:chain": "tsx examples/openai-tool-chain-smoke.ts",
    "smoke:amazon-bedrock-vai:text": "tsx examples/amazon-bedrock-vai-smoke.ts",
    "smoke:amazon-bedrock-vai:tool": "tsx examples/amazon-bedrock-vai-tool-smoke.ts",
    "smoke:amazon-bedrock-vai:chain": "tsx examples/amazon-bedrock-vai-tool-chain-smoke.ts",
    "smoke:amazon-bedrock-vai:runtime": "tsx examples/amazon-bedrock-vai.ts",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); for (const f of fs.readdirSync('.')) if (/^hyper-router-.*\\.tgz$/.test(f)) fs.rmSync(f,{force:true});\"",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "agent",
    "sdk",
    "runtime",
    "typescript",
    "node"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.92",
    "@ai-sdk/openai": "^3.0.53",
    "@openrouter/agent": "^0.3.2",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "ai": "^6.0.168",
    "pg": "^8.13.1",
    "sql.js": "^1.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.92",
    "@ai-sdk/openai": "^3.0.53",
    "@openrouter/agent": "^0.3.2",
    "ai": "^6.0.168",
    "pg": "^8.13.1",
    "sql.js": "^1.14.1",
    "zod": "^4.1.12"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@openrouter/agent": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "sql.js": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }

}
